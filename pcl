a) Read a character using getchar() and display it using putchar()

#include <stdio.h>

int main() {
    char ch;

    printf("Enter a character: ");
    ch = getchar();     // Reads a single character
    printf("You entered: ");
    putchar(ch);        // Displays the same character

    return 0;
}


⸻

b) Read two integers using scanf() and display their sum, difference, product, and quotient

#include <stdio.h>

int main() {
    int a, b;

    printf("Enter two integers: ");
    scanf("%d %d", &a, &b);  // Reads two integers

    printf("Sum = %d\n", a + b);
    printf("Difference = %d\n", a - b);
    printf("Product = %d\n", a * b);
    printf("Quotient = %d\n", a / b);

    return 0;
}


⸻

c) Read a string (full name) using gets() and display it using puts()

#include <stdio.h>

int main() {
    char name[100];

    printf("Enter your full name: ");
    gets(name);       // Reads string (unsafe but simple for learning)
    printf("Your full name is: ");
    puts(name);       // Displays the string

    return 0;
}


