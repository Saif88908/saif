3.1 nested structure

#include <stdio.h>

int main() {
    int choice, i;

    while (1) {   // Outer loop — runs until 'break' is used
        printf("\n--- Menu ---\n");
        printf("1. Print numbers 1 to 5\n");
        printf("2. Skip number 3 using continue\n");
        printf("3. Exit program\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Numbers from 1 to 5:\n");
                for (i = 1; i <= 5; i++) {
                    printf("%d ", i);
                }
                printf("\n");
                break;

            case 2:
                printf("Numbers from 1 to 5 (skipping 3):\n");
                for (i = 1; i <= 5; i++) {
                    if (i == 3)
                        continue;  // Skips number 3
                    printf("%d ", i);
                }
                printf("\n");
                break;

            case 3:
                printf("Exiting program...\n");
                break;   // Breaks from switch
            default:
                printf("Invalid choice! Try again.\n");
        }

        if (choice == 3)
            break;  // Breaks from while loop
    }

    return 0;
}


3.2 goto


#include <stdio.h>

int main() {
    int choice, i;

menu:   // Label for goto
    printf("\n--- Menu ---\n");
    printf("1. Print numbers 1 to 5\n");
    printf("2. Skip number 3 using continue\n");
    printf("3. Go back to menu using goto\n");
    printf("4. Exit program\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            printf("Numbers from 1 to 5:\n");
            for (i = 1; i <= 5; i++) {
                printf("%d ", i);
            }
            printf("\n");
            break;

        case 2:
            printf("Numbers from 1 to 5 (skipping 3):\n");
            for (i = 1; i <= 5; i++) {
                if (i == 3)
                    continue;   // Skips 3
                printf("%d ", i);
            }
            printf("\n");
            break;

        case 3:
            printf("Returning to menu using goto...\n");
            goto menu;          // Jumps back to label
            break;

        case 4:
            printf("Exiting program...\n");
            return 0;           // Ends the program

        default:
            printf("Invalid choice! Try again.\n");
            goto menu;          // Return to menu on invalid input
    }

    goto menu;  // After executing any valid case, go back to menu
}


